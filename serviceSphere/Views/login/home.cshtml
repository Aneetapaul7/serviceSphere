@model IEnumerable<serviceSphere.sp_get_all_services_Result>

@{
    ViewBag.Title = "home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="margin-top:120px; padding-left:20px; padding-right:20px;">

    <div class="row g-4" style="margin-left:0; margin-right:0;">

        @foreach (var item in Model)
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-3" style="padding-left:12px; padding-right:12px;">

                <div class="card shadow-sm h-100"
                     style="border-radius:12px; overflow:hidden;">

                    <img src="@Url.Content(item.service_image)"
                         class="card-img-top"
                         style="height:200px; width:100%; object-fit:cover;" />

                    <div class="card-body d-flex flex-column" style="padding:16px;">

                        <h5 style="font-size:18px; font-weight:600; margin-bottom:10px;">
                            @item.service_name
                        </h5>
                        <p style="font-size:14px; color:#555; margin-bottom:8px;">
                             <b>@item.bussiness_name</b>
                        </p>

                        <p style="font-size:14px; height:45px; overflow:hidden; margin-bottom:10px;">
                            @item.service_description
                        </p>

                        <p style="font-size:14px; margin-bottom:6px;">
                            Rating : ⭐ @item.rating
                        </p>

                        <h6 style="margin-bottom:8px;">
                            <span class="text-success">
                                ₹ @item.service_price
                            </span>
                        </h6>

                        <p style="font-size:14px; margin-bottom:12px;">
                            📍 @item.location
                        </p>

                        <a href="@Url.Action("BookService", "booking", new { service_id = item.service_id, provider_id = item.provider_regid })"
                           class="btn btn-primary btn-sm mt-auto">
                            Book Now
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>