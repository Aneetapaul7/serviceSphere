@model serviceSphere.Models.login
@{
    ViewBag.Title = "login_pageload";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: #f5f7fb;
    }

    .login-box {
        width: 95%;
        max-width: 500px;
        margin: 70px auto;
        padding: 40px 32px;
        border-radius: 22px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        border: 1px solid #ececec;
        box-sizing: border-box;
    }

    .login-title {
        text-align: center;
        font-size: 34px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 8px;
    }

    .login-subtitle {
        text-align: center;
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 30px;
    }

    .form-group {
        width: 100%;
        margin-bottom: 22px;
    }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
            font-weight: 600;
            color: #374151;
        }

    .form-control {
        width: 100%;
        display: block;
        height: 52px;
        padding: 12px 16px;
        border: 1px solid #dcdfe4;
        border-radius: 12px;
        font-size: 15px;
        background: #fafafa;
        transition: 0.3s ease;
        box-sizing: border-box;
    }
        .form-control:focus {
            border-color: #111827;
            background: #fff;
            box-shadow: 0 0 0 4px rgba(17,24,39,0.08);
            outline: none;
        }

    .text-danger {
        color: #dc2626;
        font-size: 12px;
        margin-top: 5px;
        display: block;
    }

    .login-btn {
        width: 100%;
        height: 50px;
        border: none;
        border-radius: 14px;
        background: linear-gradient(135deg, #111827, #000000);
        color: #fff;
        font-size: 15px;
        font-weight: 600;
        transition: 0.3s ease;
        margin-top: 10px;
    }

        .login-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

    .success-msg {
        text-align: center;
        margin-top: 18px;
        color: #dc2626;
        font-weight: 600;
        font-size: 14px;
    }
    .login-box {
        width: 95%;
        max-width: 500px;
        margin: 70px auto;
        padding: 40px 40px;
    }
    .form-group {
        width: 100%;
    }

        .form-group input {
            width: 100% !important;
            min-width: 100%;
        }

    @@media(max-width:600px) {
        .login-box {
            margin: 20px;
            padding: 28px 22px;
        }

        .login-title {
            font-size: 28px;
        }
    }
</style>

<div class="login-box">

    <div class="login-title">
        Login Here
    </div>

    <div class="login-subtitle">
        Login to continue your account
    </div>

    @using (Html.BeginForm("login_click", "login", FormMethod.Get))
    {

        <div class="form-group">
            <label>Username</label>
            @Html.TextBoxFor(m => m.username,
                new { @class = "form-control", placeholder = "Enter username" })
            @Html.ValidationMessageFor(m => m.username, "",
                new { @class = "text-danger" })
        </div>

        <div class="form-group">
            <label>Password</label>
            @Html.PasswordFor(m => m.password,
                new { @class = "form-control", placeholder = "Enter password" })
            @Html.ValidationMessageFor(m => m.password, "",
                new { @class = "text-danger" })
        </div>

        <button type="submit" class="login-btn">
            Login
        </button>

        <div class="success-msg">
            @Html.DisplayFor(m => m.msg)
        </div>

    }

</div>