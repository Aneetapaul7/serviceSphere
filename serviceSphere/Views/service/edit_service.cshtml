@model serviceSphere.sp_get_service_by_id_Result

@{
    ViewBag.Title = "edit_service";
    Layout = "~/Views/Shared/_ProviderLayout.cshtml";
}

<h2>Edit Service</h2>

@using (Html.BeginForm("edit_service_click",
                       "service",
                       FormMethod.Post,
                       new { enctype = "multipart/form-data" }))
{

    @Html.HiddenFor(m => m.service_id)


    <!-- OLD IMAGE HIDDEN -->

    <input type="hidden"
           name="service_image"
           value="@Model.service_image" />



    <div>
        <label>Service Name</label>

        @Html.TextBoxFor(m => m.service_name,
        new { @class = "form-control" })
    </div>

    <br />



    <div>
        <label>Description</label>

        @Html.TextAreaFor(m => m.service_description,
        new { @class = "form-control" })
    </div>

    <br />



    <div>
        <label>Price</label>

        @Html.TextBoxFor(m => m.service_price,
        new { @class = "form-control" })
    </div>

    <br />



    <div>
        <label>Location</label>

        @Html.TextBoxFor(m => m.location,
        new { @class = "form-control" })
    </div>

    <br />



    <div>
        <label>Status</label>

        @Html.TextBoxFor(m => m.service_status,
        new { @class = "form-control" })
    </div>

    <br />



    <!-- CURRENT IMAGE -->

    <div>

        <label>Current Image</label>

        <br />

        <img src="~/photos/@Model.service_image"
             width="120"
             height="100" />

    </div>

    <br />



    <!-- NEW IMAGE -->

    <div>

        <label>Change Image</label>

        <input type="file"
               name="file"
               class="form-control" />

    </div>

    <br />



    <div>

        <input type="submit"
               value="Update"
               class="btn btn-success" />

    </div>
}