@model serviceSphere.Models.userinsert
@{
    ViewBag.Title = "userreg_pageload";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

    <style >
    body {
        background: #f5f7fb;
    }

    .register-box {
        width: 95%;
        max-width: 540px;
        margin: 50px auto;
        padding: 35px 32px;
        border-radius: 22px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        border: 1px solid #ececec;
        box-sizing: border-box;
    }

    .register-title {
        text-align: center;
        font-size: 34px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 8px;
    }

    .register-subtitle {
        text-align: center;
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 30px;
    }

    .form-group {
        width: 100%;
        margin-bottom: 20px;
    }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
            font-weight: 600;
            color: #374151;
        }

        .form-control {
            display: block;
            width: 100%;
            max-width: 100%;
            height: 48px;
            padding: 12px 15px;
            border: 1px solid #dcdfe4;
            border-radius: 12px;
            font-size: 14px;
            background: #fafafa;
            transition: 0.3s ease;
            box-sizing: border-box;
        }

    textarea.form-control {
        height: 90px;
        resize: none;
        padding-top: 12px;
    }

    .form-control:focus {
        border-color: #111827;
        background: #fff;
        box-shadow: 0 0 0 4px rgba(17,24,39,0.08);
        outline: none;
    }

    .text-danger {
        color: #dc2626;
        font-size: 12px;
        margin-top: 5px;
        display: block;
    }

    .register-btn {
        width: 100%;
        height: 50px;
        border: none;
        border-radius: 14px;
        background: linear-gradient(135deg, #111827, #000000);
        color: #fff;
        font-size: 15px;
        font-weight: 600;
        letter-spacing: 0.3px;
        transition: 0.3s ease;
        margin-top: 10px;
    }

        .register-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

    .success-msg {
        text-align: center;
        margin-top: 18px;
        color: #16a34a;
        font-weight: 600;
        font-size: 14px;
    }

    @@media(max-width:600px) {
        .register-box {
            margin: 20px;
            padding: 28px 22px;
        }

        .register-title {
            font-size: 28px;
        }
    }

        .register-box form {
            width: 100%;
        }

        .form-group {
            width: 100%;
        }

            .form-group input,
            .form-group textarea {
                width: 100% !important;
            }
</style>

<div class="register-box">

    <div class="register-title">
        User Registration
    </div>

    <div class="register-subtitle">
        Create your account to continue
    </div>

    @using (Html.BeginForm("userreg_click", "userreg", FormMethod.Post))
    {
        <div class="form-group">
            <label>Name</label>
            @Html.TextBoxFor(m => m.name, new { @class = "form-control", placeholder = "Enter your full name" })
            @Html.ValidationMessageFor(m => m.name, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            <label>Address</label>
            @Html.TextAreaFor(m => m.address, new { @class = "form-control", placeholder = "Enter your address" })
        </div>

        <div class="form-group">
            <label>Phone</label>
            @Html.TextBoxFor(m => m.phone, new { @class = "form-control", placeholder = "Enter phone number" })
            @Html.ValidationMessageFor(m => m.phone, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            <label>Email</label>
            @Html.TextBoxFor(m => m.email, new { @class = "form-control", placeholder = "Enter email address" })
            @Html.ValidationMessageFor(m => m.email, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            <label>Username</label>
            @Html.TextBoxFor(m => m.username, new { @class = "form-control", placeholder = "Create username" })
            @Html.ValidationMessageFor(m => m.username, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            <label>Password</label>
            @Html.PasswordFor(m => m.pass, new { @class = "form-control", placeholder = "Enter password" })
        </div>

        <div class="form-group">
            <label>Confirm Password</label>
            @Html.PasswordFor(m => m.cpassword, new { @class = "form-control", placeholder = "Confirm password" })
            @Html.ValidationMessageFor(m => m.cpassword, "", new { @class = "text-danger" })
        </div>

        <button type="submit" class="register-btn">
            Create Account
        </button>

        <div class="success-msg">
            @Html.DisplayFor(m => m.usermsg)
        </div>
    }

</div>