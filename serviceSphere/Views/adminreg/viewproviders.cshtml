@{
    ViewBag.Title = "viewproviders";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    body {
        background: #f5f7fb;
    }

    .page-title {
        font-size: 28px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 25px;
    }

    .table-box {
        background: #ffffff;
        padding: 22px;
        border-radius: 16px;
        box-shadow: 0 4px 18px rgba(0,0,0,0.06);
        margin-bottom: 35px;
    }

    .section-title {
        font-size: 22px;
        font-weight: 600;
        color: #111827;
        margin-bottom: 18px;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
    }

        .custom-table th {
            background: #111827;
            color: #ffffff;
            padding: 14px;
            text-align: left;
            font-size: 14px;
        }

        .custom-table td {
            padding: 14px;
            border-bottom: 1px solid #e5e7eb;
            font-size: 14px;
            color: #374151;
        }

        .custom-table tr:hover {
            background: #f9fafb;
        }

    .action-btn {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 8px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        color: white;
    }

    .approve-btn {
        background: #16a34a;
    }

    .block-btn {
        background: #dc2626;
    }

    .unblock-btn {
        background: #2563eb;
    }
</style>

<h2 class="page-title">Service Providers Management</h2>

<div class="table-box">

    <h3 class="section-title">Pending Providers</h3>

    <table class="custom-table">

        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Action</th>
        </tr>

        @foreach (var item in ViewBag.pending)
        {
            <tr>

                <td>@item.bussiness_name</td>
                <td>@item.email</td>

                <td>
                    @Html.ActionLink(
                    "Approve",
                    "approve_provider",
                    new { id = item.provider_id },
                    new { @class = "action-btn approve-btn" })
                </td>

            </tr>
        }

    </table>

</div>

<div class="table-box">

    <h3 class="section-title">Approved Providers</h3>

    <table class="custom-table">

        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Action</th>
        </tr>

        @foreach (var item in ViewBag.approved)
        {
            <tr>

                <td>@item.bussiness_name</td>
                <td>@item.email</td>

                <td>
                    @Html.ActionLink(
                    "Block",
                    "block_provider",
                    new { id = item.provider_id },
                    new { @class = "action-btn block-btn" })
                </td>

            </tr>
        }

    </table>

</div>

<div class="table-box">

    <h3 class="section-title">Blocked Providers</h3>

    <table class="custom-table">

        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Action</th>
        </tr>

        @foreach (var item in ViewBag.blocked)
        {
            <tr>

                <td>@item.bussiness_name</td>
                <td>@item.email</td>

                <td>
                    @Html.ActionLink(
                    "Unblock",
                    "unblock_provider",
                    new { id = item.provider_id },
                    new { @class = "action-btn unblock-btn" })
                </td>

            </tr>
        }

    </table>

</div>