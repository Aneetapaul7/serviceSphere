
@model serviceSphere.booking
@{
    ViewBag.Title = "BookService";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>BookService</h2>

<div class="container" style="margin-top:120px;">

    <h2>Book Service</h2>

    <div class="alert alert-info">
    <strong>Service:</strong> @ViewBag.ServiceName
</div>

   @using (Html.BeginForm("BookService", "booking", FormMethod.Post))
    {
        @Html.HiddenFor(m => m.service_id)
        @Html.HiddenFor(m => m.provider_id)

        <div class="form-group">
            <label>Service Date</label>
            @Html.TextBoxFor(m => m.service_date,
                new { @class = "form-control", type = "date" })
        </div>

        <div class="form-group">
            <label>Service Time</label>
            @Html.TextBoxFor(m => m.service_time,
                new { @class = "form-control", placeholder = "10:00 AM" })
        </div>

        <div class="form-group">
            <label>Address</label>
            @Html.TextAreaFor(m => m.address,
                new { @class = "form-control", rows = "3" })
        </div>

        <div class="form-group">
            <label>Description</label>
            @Html.TextAreaFor(m => m.description,
                new { @class = "form-control", rows = "4" })
        </div>

        <br />

        <input type="submit"
               value="Confirm Booking"
               class="btn btn-success" />
    }

</div>